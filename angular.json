{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"cli": {
		"packageManager": "npm"
	},
	"newProjectRoot": "projects",
	"projects": {
		"app-shop": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss",
					"skipTests": true
				},
				"@schematics/angular:class": {
					"skipTests": true
				},
				"@schematics/angular:directive": {
					"skipTests": true
				},
				"@schematics/angular:guard": {
					"skipTests": true
				},
				"@schematics/angular:interceptor": {
					"skipTests": true
				},
				"@schematics/angular:pipe": {
					"skipTests": true
				},
				"@schematics/angular:resolver": {
					"skipTests": true
				},
				"@schematics/angular:service": {
					"skipTests": true
				}
			},
			"root": "",
			"sourceRoot": "src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular-architects/native-federation:build",
					"options": {},
					"configurations": {
						"production": {
							"target": "app-shop:esbuild:production"
						},
						"development": {
							"target": "app-shop:esbuild:development",
							"dev": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular-architects/native-federation:build",
					"options": {
						"target": "app-shop:serve-original:development",
						"rebuildDelay": 500,
						"dev": true,
						"cacheExternalArtifacts": true,
						"port": 0
					}
				},
				"esbuild": {
					"builder": "@angular/build:application",
					"options": {
						"browser": "src/main.ts",
						"tsConfig": "tsconfig.app.json",
						"inlineStyleLanguage": "css",
						"assets": [
							{
								"glob": "**/*",
								"input": "public"
							},
							{
								"glob": "**/*",
								"input": "src/assets",
								"output": "/assets"
							}
						],
						"styles": [
							"src/styles.scss"
						],
						"stylePreprocessorOptions": {
							"sass": {
								"silenceDeprecations": [
									"import",
									"global-builtin"
								]
							}
						},
						"polyfills": [
							"es-module-shims"
						]
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "1MB",
									"maximumError": "2MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "100kB",
									"maximumError": "200kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve-original": {
					"builder": "@angular/build:dev-server",
					"options": {
						"proxyConfig": "proxy.conf.json",
						"port": 4200
					},
					"configurations": {
						"production": {
							"buildTarget": "app-shop:esbuild:production"
						},
						"development": {
							"buildTarget": "app-shop:esbuild:development"
						}
					},
					"defaultConfiguration": "development"
				}
			}
		},
		"auth-lib": {
			"projectType": "library",
			"root": "projects/auth-lib",
			"sourceRoot": "projects/auth-lib/src",
			"prefix": "lib",
			"architect": {
				"build": {
					"builder": "@angular/build:ng-packagr",
					"configurations": {
						"production": {
							"tsConfig": "projects/auth-lib/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": "projects/auth-lib/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"tsConfig": "projects/auth-lib/tsconfig.spec.json"
					}
				}
			}
